# Copier ce fichier en .env et remplir les valeurs

# PostgreSQL
DB_USER=osiris_user
DB_PASSWORD=changeme
DB_HOST=localhost
DB_NAME=osiris

# API
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=changeme

# Réseau PXE (IP vue par les machines qui bootent)
OSIRIS_BASE_URL=http://10.0.0.1:8000
OSIRIS_IP=10.0.0.1

# Frontend (origines autorisées pour le CORS)
ALLOWED_ORIGINS=http://localhost:5173

# Clé SSH publique déposée sur chaque machine Ubuntu déployée (optionnel)
OSIRIS_SSH_PUBKEY=
