#Requires -RunAsAdministrator
<#
    OSIRIS - Premier demarrage Windows - {{ machine.hostname }}
    Genere a la volee par OSIRIS, telecharge pendant le deploiement WinPE.
#>

$ErrorActionPreference = "Continue"
$logFile = "C:\osiris-firstboot.log"
$osirisUrl = "{{ osiris_url }}"
$script:_mac = $null  # sera defini apres detection reseau

# En cas d'erreur fatale non capturee, signaler l'echec a OSIRIS
trap {
    $errMsg = $_.Exception.Message -replace '"', "'"
    Write-Host "$(Get-Date -Format 'HH:mm:ss') ERREUR FATALE : $errMsg"
    Add-Content -Path $logFile -Value "$(Get-Date -Format 'HH:mm:ss') ERREUR FATALE : $errMsg" -EA SilentlyContinue
    if ($script:_mac) {
        try {
            Invoke-WebRequest -Uri "$osirisUrl/machines/$($script:_mac)/status?status=failed" `
                -Method POST -UseBasicParsing -TimeoutSec 10 | Out-Null
        } catch {}
    }
    continue
}

function Write-Log($msg) {
    $line = "$(Get-Date -Format 'HH:mm:ss') $msg"
    Write-Host $line
    Add-Content -Path $logFile -Value $line
}

Write-Log "=========================================="
Write-Log "OSIRIS First Boot - {{ machine.hostname }}"
Write-Log "=========================================="

# ── Attendre que le reseau soit disponible ───────────────────────────────────
Write-Log "Attente de la connectivite reseau..."
$retries = 0
while ($retries -lt 30) {
    try {
        $null = Invoke-WebRequest -Uri "$osirisUrl/" -UseBasicParsing -TimeoutSec 3 -ErrorAction Stop
        break
    } catch {
        Start-Sleep -Seconds 5
        $retries++
    }
}

# ── Recuperer la vraie adresse MAC ───────────────────────────────────────────
$adapter = Get-NetAdapter | Where-Object { $_.Status -eq "Up" -and $_.HardwareInterface } | Select-Object -First 1
if ($adapter) {
    $mac = $adapter.MacAddress -replace '-', '' | ForEach-Object { $_.ToLower() }
    $script:_mac = $mac
    Write-Log "MAC detectee : $mac"
} else {
    Write-Log "ERREUR : aucun adaptateur reseau actif"
    $mac = $null
}

# ── Inventaire materiel ───────────────────────────────────────────────────────
Write-Log "Collecte des informations materiel..."
try {
    $cs   = Get-CimInstance -ClassName Win32_ComputerSystem -ErrorAction Stop
    $bios = Get-CimInstance -ClassName Win32_BIOS           -ErrorAction Stop
    $hwSerial = $bios.SerialNumber.Trim()
    $hwModel  = "$($cs.Manufacturer.Trim()) $($cs.Model.Trim())"
    $hwRamGb  = [math]::Round($cs.TotalPhysicalMemory / 1GB)
    Write-Log "Materiel : $hwModel | S/N : $hwSerial | RAM : ${hwRamGb} Go"

    if ($mac) {
        $hwBody = @{ serial = $hwSerial; model = $hwModel; ram_gb = $hwRamGb } | ConvertTo-Json
        Invoke-WebRequest -Uri "$osirisUrl/machines/$mac/hardware" `
            -Method POST -Body $hwBody -ContentType "application/json" `
            -UseBasicParsing -TimeoutSec 10 -ErrorAction Stop | Out-Null
        Write-Log "Inventaire materiel envoye a OSIRIS"
    }
} catch {
    Write-Log "AVERTISSEMENT : collecte materiel echouee - $_"
}

# ── Callback "deployed" ──────────────────────────────────────────────────────
if ($mac) {
    try {
        $resp = Invoke-WebRequest -Uri "$osirisUrl/machines/$mac/status?status=deployed" `
            -Method POST -UseBasicParsing -TimeoutSec 10 -ErrorAction Stop
        Write-Log "Statut 'deployed' confirme (HTTP $($resp.StatusCode))"
    } catch {
        Write-Log "AVERTISSEMENT : callback echoue - $_"
    }
}

# ── LAPS - Mot de passe administrateur local unique ───────────────────────────
Write-Log "Generation du mot de passe administrateur local (LAPS)..."
try {
    $chars = 'abcdefghjkmnpqrstuvwxyzABCDEFGHJKMNPQRSTUVWXYZ23456789!@#$%'.ToCharArray()
    $lapsPassword = -join ((1..16) | ForEach-Object { $chars | Get-Random })
    $secLaps = ConvertTo-SecureString $lapsPassword -AsPlainText -Force
    Set-LocalUser -Name "Administrator" -Password $secLaps -ErrorAction Stop
    Enable-LocalUser -Name "Administrator" -ErrorAction SilentlyContinue
    Write-Log "Mot de passe administrateur local defini"

    if ($mac) {
        $lapsBody = @{ password = $lapsPassword } | ConvertTo-Json
        Invoke-WebRequest -Uri "$osirisUrl/machines/$mac/laps-password" `
            -Method POST -Body $lapsBody -ContentType "application/json" `
            -UseBasicParsing -TimeoutSec 10 | Out-Null
        Write-Log "Mot de passe LAPS sauvegarde dans OSIRIS"
    }
} catch {
    Write-Log "AVERTISSEMENT : LAPS echoue - $_"
}

{% if profile.enable_bitlocker %}
# ── BitLocker ─────────────────────────────────────────────────────────────────
{% if profile.bitlocker_pin %}
Write-Log "Activation de BitLocker (mode TPM + PIN)..."
{% else %}
Write-Log "Activation de BitLocker (mode TPM automatique)..."
{% endif %}
try {
    $tpm = Get-Tpm -ErrorAction Stop
    if (-not $tpm.TpmPresent -or -not $tpm.TpmReady) {
        Write-Log "AVERTISSEMENT : TPM absent ou non pret - BitLocker ignore"
    } else {
        $blVol = Get-BitLockerVolume -MountPoint "C:" -ErrorAction Stop

        # Recuperer ou generer la cle de recuperation
        $existingKey = ($blVol.KeyProtector | Where-Object { $_.KeyProtectorType -eq "RecoveryPassword" } | Select-Object -First 1).RecoveryPassword
        if (-not $existingKey) {
            Add-BitLockerKeyProtector -MountPoint "C:" -RecoveryPasswordProtector -ErrorAction Stop | Out-Null
            $blVol = Get-BitLockerVolume -MountPoint "C:"
            $existingKey = ($blVol.KeyProtector | Where-Object { $_.KeyProtectorType -eq "RecoveryPassword" } | Select-Object -First 1).RecoveryPassword
        }

        {% if profile.bitlocker_pin %}
        # Mode TPM + PIN : generer un PIN aleatoire a 6 chiffres
        $pin = (Get-Random -Minimum 100000 -Maximum 999999).ToString()
        $securePin = ConvertTo-SecureString $pin -AsPlainText -Force

        $hasTpmPin = ($blVol.KeyProtector | Where-Object { $_.KeyProtectorType -eq "TpmPin" }).Count -gt 0
        if (-not $hasTpmPin) {
            Add-BitLockerKeyProtector -MountPoint "C:" -TpmAndPinProtector -Pin $securePin -ErrorAction Stop | Out-Null
        }
        if ($blVol.ProtectionStatus -ne "On") {
            Enable-BitLocker -MountPoint "C:" -EncryptionMethod XtsAes256 -SkipHardwareTest -ErrorAction Stop | Out-Null
        }
        Write-Log "BitLocker TPM+PIN active - PIN : $pin"

        if ($mac) {
            $blBody = @{ key = $existingKey; pin = $pin } | ConvertTo-Json
            Invoke-WebRequest -Uri "$osirisUrl/machines/$mac/bitlocker-key" `
                -Method POST -Body $blBody -ContentType "application/json" `
                -UseBasicParsing -TimeoutSec 10 | Out-Null
            Write-Log "PIN et cle de recuperation sauvegardes dans OSIRIS"
        }
        {% else %}
        # Mode TPM seul : demarrage automatique
        if ($blVol.ProtectionStatus -ne "On") {
            Enable-BitLocker -MountPoint "C:" -EncryptionMethod XtsAes256 `
                -TpmProtector -SkipHardwareTest -ErrorAction Stop | Out-Null
        }
        Write-Log "BitLocker TPM seul active"

        if ($mac -and $existingKey) {
            $blBody = @{ key = $existingKey } | ConvertTo-Json
            Invoke-WebRequest -Uri "$osirisUrl/machines/$mac/bitlocker-key" `
                -Method POST -Body $blBody -ContentType "application/json" `
                -UseBasicParsing -TimeoutSec 10 | Out-Null
            Write-Log "Cle de recuperation sauvegardee dans OSIRIS"
        }
        {% endif %}
    }
} catch {
    Write-Log "AVERTISSEMENT : BitLocker echoue - $_"
}
{% else %}
Write-Log "BitLocker desactive sur ce profil."
{% endif %}

{% if tv_password %}
# ── TeamViewer ───────────────────────────────────────────────────────────────
$tvPassword = "{{ tv_password }}"
$tvExe = if (Test-Path "C:\Program Files\TeamViewer\TeamViewer.exe") {
    "C:\Program Files\TeamViewer\TeamViewer.exe"
} elseif (Test-Path "C:\Program Files (x86)\TeamViewer\TeamViewer.exe") {
    "C:\Program Files (x86)\TeamViewer\TeamViewer.exe"
} else { $null }

if ($tvExe) {
    foreach ($p in @("HKLM:\SOFTWARE\TeamViewer", "HKLM:\SOFTWARE\WOW6432Node\TeamViewer")) {
        if (Test-Path $p) { Set-ItemProperty -Path $p -Name "LicenseAccepted" -Value 1 -Type DWord -EA SilentlyContinue }
    }
    & $tvExe --passwd $tvPassword | Out-Null
    Write-Log "TeamViewer : mot de passe defini"
} else {
    Write-Log "AVERTISSEMENT : TeamViewer introuvable (a installer dans la golden image)"
}
{% endif %}

{% if win_apps %}
# ── Applications winget ───────────────────────────────────────────────────────
Write-Log "Installation des applications via winget..."
$apps = @(
{% for app in win_apps %}
    "{{ app.winget_id }}"{{ "," if not loop.last else "" }}
{% endfor %}
)
foreach ($appId in $apps) {
    Write-Log "winget : $appId"
    winget install --id $appId -e `
        --accept-source-agreements `
        --accept-package-agreements `
        --silent 2>&1 | ForEach-Object { Write-Log "  $_" }
}
Write-Log "Applications installees."
{% endif %}

{% if profile.network_drives %}
# ── Lecteurs reseau ───────────────────────────────────────────────────────────
Write-Log "Mapping des lecteurs reseau..."
{% for drive in profile.network_drives %}
try {
    New-PSDrive -Name "{{ drive.letter }}" -PSProvider FileSystem -Root "{{ drive.path }}" -Persist -Scope Global -ErrorAction Stop | Out-Null
    Write-Log "Lecteur {{ drive.letter }}: -> {{ drive.path }}"
} catch {
    Write-Log "AVERTISSEMENT : Lecteur {{ drive.letter }}: echoue - $_"
}
{% endfor %}
{% endif %}

{% if profile.printers %}
# ── Imprimantes reseau ────────────────────────────────────────────────────────
Write-Log "Ajout des imprimantes reseau..."
{% for printer in profile.printers %}
try {
    Add-Printer -ConnectionName "{{ printer }}" -ErrorAction Stop
    Write-Log "Imprimante ajoutee : {{ printer }}"
} catch {
    Write-Log "AVERTISSEMENT : Imprimante {{ printer }} echouee - $_"
}
{% endfor %}
{% endif %}

{% if profile.post_script %}
# ── Script post-install personnalise ─────────────────────────────────────────
Write-Log "Execution du script post-install personnalise..."
try {
{{ profile.post_script }}
} catch {
    Write-Log "AVERTISSEMENT : Script post-install - $_"
}
Write-Log "Script post-install termine."
{% endif %}

{% if profile.laps_rotation_days > 0 %}
# ── LAPS : rotation automatique ───────────────────────────────────────────────
Write-Log "Installation du script de rotation LAPS (tous les {{ profile.laps_rotation_days }} jours)..."

$lapsScript = @'
#Requires -RunAsAdministrator
# OSIRIS - Rotation automatique du mot de passe administrateur local (LAPS)
$osirisUrl = "{{ osiris_url }}"
$ErrorActionPreference = "Stop"

try {
    $mac = (Get-NetAdapter | Where-Object { $_.Status -eq "Up" -and $_.MacAddress -ne "" } `
        | Sort-Object -Property InterfaceIndex | Select-Object -First 1).MacAddress -replace '-', '' -replace ':', ''

    $check = Invoke-RestMethod -Uri "$osirisUrl/machines/$mac/laps-due" -Method GET -TimeoutSec 10
    if (-not $check.due) { exit 0 }

    $chars = 'abcdefghjkmnpqrstuvwxyzABCDEFGHJKMNPQRSTUVWXYZ23456789!@#$%'.ToCharArray()
    $newPassword = -join ((1..16) | ForEach-Object { $chars | Get-Random })
    $securePassword = ConvertTo-SecureString $newPassword -AsPlainText -Force

    Set-LocalUser -Name "Administrator" -Password $securePassword -ErrorAction Stop

    $body = @{ password = $newPassword } | ConvertTo-Json
    Invoke-RestMethod -Uri "$osirisUrl/machines/$mac/laps-password" -Method POST `
        -ContentType "application/json" -Body $body -TimeoutSec 10 | Out-Null

    Write-EventLog -LogName Application -Source "OSIRIS" -EventId 1042 `
        -EntryType Information -Message "LAPS : mot de passe Administrator renouvele." `
        -ErrorAction SilentlyContinue
} catch {
    Write-EventLog -LogName Application -Source "OSIRIS" -EventId 1043 `
        -EntryType Warning -Message "LAPS : echec de la rotation - $_" `
        -ErrorAction SilentlyContinue
}
'@

$lapsScriptPath = "C:\Windows\System32\osiris-laps-renew.ps1"
Set-Content -Path $lapsScriptPath -Value $lapsScript -Encoding UTF8

# Enregistrer la source d'evenement Windows si elle n'existe pas
if (-not [System.Diagnostics.EventLog]::SourceExists("OSIRIS")) {
    New-EventLog -LogName Application -Source "OSIRIS" -ErrorAction SilentlyContinue
}

# Tache planifiee : rotation au demarrage, sous SYSTEM
$action    = New-ScheduledTaskAction -Execute "PowerShell.exe" `
    -Argument "-NonInteractive -WindowStyle Hidden -ExecutionPolicy Bypass -File `"$lapsScriptPath`""
$trigger   = New-ScheduledTaskTrigger -AtStartup
$principal = New-ScheduledTaskPrincipal -UserId "SYSTEM" -LogonType ServiceAccount -RunLevel Highest
$settings  = New-ScheduledTaskSettingsSet -ExecutionTimeLimit (New-TimeSpan -Minutes 5)
Register-ScheduledTask -TaskName "OSIRIS-LAPS-Renewal" `
    -Action $action -Trigger $trigger -Principal $principal -Settings $settings `
    -Description "OSIRIS - Rotation automatique LAPS tous les {{ profile.laps_rotation_days }} jours" `
    -Force | Out-Null
Write-Log "Tache planifiee OSIRIS-LAPS-Renewal creee."
{% endif %}

Write-Log "Premier demarrage OSIRIS termine."

# ── Smoke tests ───────────────────────────────────────────────────────────────
Write-Log "Smoke tests post-deploiement..."
$smokeTests = @()

function Add-SmokeTest($name, $ok, $detail = "") {
    $script:smokeTests += @{ name = $name; ok = $ok; detail = $detail }
    $icon = if ($ok) { "OK" } else { "FAIL" }
    Write-Log "  [$icon] $name$(if ($detail) { ' : ' + $detail } else { '' })"
}

# Ping passerelle par defaut
try {
    $gw = (Get-NetRoute -DestinationPrefix "0.0.0.0/0" | Sort-Object RouteMetric | Select-Object -First 1).NextHop
    $ping = Test-Connection -ComputerName $gw -Count 1 -Quiet -ErrorAction Stop
    Add-SmokeTest "Ping passerelle ($gw)" $ping
} catch {
    Add-SmokeTest "Ping passerelle" $false "Erreur : $_"
}

# Resolution DNS
try {
    $dns = [System.Net.Dns]::GetHostEntry("www.google.com") -ne $null
    Add-SmokeTest "Resolution DNS" $true
} catch {
    Add-SmokeTest "Resolution DNS" $false "Echec : $_"
}

{% if profile.join_domain %}
# Jonction domaine AD
try {
    $inDomain = (Get-WmiObject Win32_ComputerSystem).PartOfDomain
    Add-SmokeTest "Jonction domaine AD" $inDomain (if ($inDomain) { (Get-WmiObject Win32_ComputerSystem).Domain } else { "Non joint" })
} catch {
    Add-SmokeTest "Jonction domaine AD" $false "Erreur : $_"
}
{% endif %}

# Service TeamViewer
try {
    $tv = Get-Service -Name "TeamViewer" -ErrorAction Stop
    $tvOk = $tv.Status -eq "Running"
    Add-SmokeTest "TeamViewer" $tvOk $tv.Status.ToString()
} catch {
    Add-SmokeTest "TeamViewer" $false "Service introuvable"
}

{% if win_apps %}
# Presence des applications installees
{% for app in win_apps %}
try {
    $appOut = winget list --id "{{ app.winget_id }}" -e --accept-source-agreements 2>&1
    $appOk = $LASTEXITCODE -eq 0
    Add-SmokeTest "App : {{ app.name }}" $appOk (if ($appOk) { "Installe" } else { "Non trouve dans winget" })
} catch {
    Add-SmokeTest "App : {{ app.name }}" $false "Erreur winget"
}
{% endfor %}
{% endif %}

# Envoi du rapport a OSIRIS
try {
    $body = @{ tests = $smokeTests } | ConvertTo-Json -Depth 5 -Compress
    Invoke-WebRequest -Uri "$osirisUrl/machines/$($script:_mac)/smoke-tests" `
        -Method POST -Body $body -ContentType "application/json" `
        -UseBasicParsing -TimeoutSec 15 | Out-Null
    Write-Log "Rapport smoke tests envoye."
} catch {
    Write-Log "AVERTISSEMENT : Echec envoi rapport smoke tests - $_"
}

# ── Nettoyage ─────────────────────────────────────────────────────────────────
Start-Sleep -Seconds 2
Remove-Item -Path $MyInvocation.MyCommand.Path -Force -EA SilentlyContinue
