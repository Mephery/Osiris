#!/bin/bash
# OSIRIS - Premier demarrage - {{ machine.hostname }}
LOG=/var/log/osiris-firstboot.log
exec >> "$LOG" 2>&1

ts() { date '+%H:%M:%S'; }
osiris_url="{{ osiris_url }}"
_osiris_mac=""

_on_error() {
    local line=$1
    echo "[$(ts)] ERREUR FATALE a la ligne $line - firstboot interrompu" | tee -a "$LOG"
    if [ -n "$_osiris_mac" ]; then
        curl -s -X POST "$osiris_url/machines/$_osiris_mac/status?status=failed" || true
    fi
}
trap '_on_error $LINENO' ERR

echo "[$(ts)] ============================================"
echo "[$(ts)] OSIRIS First Boot - {{ machine.hostname }}"
echo "[$(ts)] ============================================"

# ── Inventaire materiel ───────────────────────────────────────────────────────
echo "[$(ts)] Collecte des informations materiel..."
HW_SERIAL=$(cat /sys/class/dmi/id/product_serial 2>/dev/null | tr -d '[:space:]') || HW_SERIAL=""
HW_MODEL=$(cat /sys/class/dmi/id/sys_vendor 2>/dev/null | tr -d '\n')
HW_PRODUCT=$(cat /sys/class/dmi/id/product_name 2>/dev/null | tr -d '\n')
HW_MODEL="$HW_MODEL $HW_PRODUCT"
HW_RAM_KB=$(grep MemTotal /proc/meminfo | awk '{print $2}')
HW_RAM_GB=$(( (HW_RAM_KB + 524288) / 1048576 ))
echo "[$(ts)] Materiel : $HW_MODEL | S/N : $HW_SERIAL | RAM : ${HW_RAM_GB} Go"

MAC=$(cat /sys/class/net/$(ip route get 8.8.8.8 2>/dev/null | awk '{print $5; exit}')/address 2>/dev/null | tr -d ':')
_osiris_mac="$MAC"
if [ -n "$MAC" ]; then
    curl -s -X POST "$osiris_url/machines/$MAC/hardware" \
        -H "Content-Type: application/json" \
        -d "{\"serial\":\"$HW_SERIAL\",\"model\":\"$HW_MODEL\",\"ram_gb\":$HW_RAM_GB}" || true
    echo "[$(ts)] Inventaire envoye a OSIRIS"
fi

{% if tv_password %}
echo "[$(ts)] Installation de TeamViewer Host..."
wget -q https://download.teamviewer.com/download/linux/teamviewer-host_amd64.deb \
     -O /tmp/osiris-tv.deb
apt-get install -y /tmp/osiris-tv.deb
rm -f /tmp/osiris-tv.deb

systemctl enable teamviewerd
systemctl start teamviewerd

echo "[$(ts)] Attente du daemon TeamViewer..."
for i in $(seq 1 10); do
    sleep 3
    if teamviewer info 2>/dev/null | grep -q "TeamViewer ID"; then
        break
    fi
done

teamviewer passwd {{ tv_password | bash_squote }}
echo "[$(ts)] TeamViewer configure - ID : $(teamviewer info 2>/dev/null | grep 'TeamViewer ID' | awk '{print $NF}')"
{% endif %}

{% if linux_apps %}
echo "[$(ts)] Installation des applications via apt..."
apt-get update -qq
{% for app in linux_apps %}
apt-get install -y {{ app.apt_package }} 2>&1 | tail -1
echo "[$(ts)] Installe : {{ app.name }}"
{% endfor %}
{% endif %}

{% if profile.join_domain and profile.domain and profile.domain_join_user and profile.domain_join_password %}
echo "[$(ts)] Jonction au domaine AD : {{ profile.domain }}"

apt-get install -y realmd sssd sssd-tools adcli krb5-user samba-common-bin \
    libnss-sss libpam-sss packagekit 2>&1 | tail -3

# Configuration Kerberos minimale pour la decouverte du domaine
cat > /etc/krb5.conf << 'KRBEOF'
[libdefaults]
    default_realm = {{ profile.domain | upper }}
    dns_lookup_realm = true
    dns_lookup_kdc = true
KRBEOF

# Jonction au domaine
{% if machine.ou %}
printf '%s' {{ profile.domain_join_password | bash_squote }} | realm join \
    --user={{ profile.domain_join_user | bash_squote }} \
    --computer-ou={{ machine.ou | bash_squote }} \
    {{ profile.domain }} 2>&1
{% else %}
printf '%s' {{ profile.domain_join_password | bash_squote }} | realm join \
    --user={{ profile.domain_join_user | bash_squote }} \
    {{ profile.domain }} 2>&1
{% endif %}

if realm list 2>/dev/null | grep -q "{{ profile.domain }}"; then
    echo "[$(ts)] Jonction AD reussie"

    # Login sans suffixe @domaine (utilisateur au lieu de utilisateur@domain.local)
    sed -i 's/use_fully_qualified_names = True/use_fully_qualified_names = False/' /etc/sssd/sssd.conf

    # Creation automatique du dossier home au premier login
    echo "session optional pam_mkhomedir.so skel=/etc/skel umask=0077" >> /etc/pam.d/common-session

    # Domain Admins en sudo sans mot de passe
    echo '%domain\ admins ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/domain-admins
    chmod 440 /etc/sudoers.d/domain-admins

    systemctl restart sssd

    echo "[$(ts)] Connexion AD disponible - login : utilisateur (sans @{{ profile.domain }})"
else
    echo "[$(ts)] ECHEC jonction AD - verifier que le DNS resout {{ profile.domain }} et que les identifiants sont corrects"
fi
{% endif %}

{% if profile.machine_type == 'server' %}
echo "[$(ts)] Configuration SSH serveur..."

# Clés SSH autorisées
mkdir -p /home/{{ profile.default_user }}/.ssh
chmod 700 /home/{{ profile.default_user }}/.ssh
{% if profile.ssh_authorized_keys %}
cat > /home/{{ profile.default_user }}/.ssh/authorized_keys << 'SSHEOF'
{{ profile.ssh_authorized_keys }}
SSHEOF
chmod 600 /home/{{ profile.default_user }}/.ssh/authorized_keys
chown -R {{ profile.default_user }}:{{ profile.default_user }} /home/{{ profile.default_user }}/.ssh
echo "[$(ts)] Cles SSH injectees"
{% endif %}

# Durcissement sshd
sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
sed -i 's/^#*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config
sed -i 's/^#*PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config
grep -q '^PasswordAuthentication' /etc/ssh/sshd_config || echo 'PasswordAuthentication no' >> /etc/ssh/sshd_config
grep -q '^PermitRootLogin' /etc/ssh/sshd_config       || echo 'PermitRootLogin no'       >> /etc/ssh/sshd_config
systemctl restart ssh 2>/dev/null || systemctl restart sshd 2>/dev/null || true
echo "[$(ts)] SSH : auth par mot de passe desactivee, root interdit"
{% endif %}

{% if profile.post_script %}
echo "[$(ts)] Execution du script post-install personnalise..."
(
{{ profile.post_script }}
) || echo "[$(ts)] AVERTISSEMENT : Script post-install termine avec une erreur"
echo "[$(ts)] Script post-install termine."
{% endif %}

echo "[$(ts)] Premier demarrage OSIRIS termine."

# ── Smoke tests ───────────────────────────────────────────────────────────────
echo "[$(ts)] Smoke tests post-deploiement..."
_smoke_json="["
_smoke_first=true

_add_test() {
    local name="$1" ok="$2" detail="${3:-}"
    local ok_val=$([ "$ok" = "true" ] && echo "true" || echo "false")
    local icon=$([ "$ok" = "true" ] && echo "OK" || echo "FAIL")
    local detail_safe=$(echo "$detail" | sed 's/"/\\"/g')
    echo "[$(ts)]   [$icon] $name${detail:+ : $detail}"
    [ "$_smoke_first" = "true" ] && _smoke_first=false || _smoke_json+=","
    _smoke_json+="{\"name\":\"$(echo "$name" | sed 's/"/\\"/g')\",\"ok\":$ok_val,\"detail\":\"$detail_safe\"}"
}

# Ping passerelle par defaut
_gw=$(ip route show default 2>/dev/null | awk '{print $3}' | head -1)
if [ -n "$_gw" ] && ping -c 1 -W 3 "$_gw" > /dev/null 2>&1; then
    _add_test "Ping passerelle ($_gw)" true
else
    _add_test "Ping passerelle" false "Passerelle inatteignable"
fi

# Resolution DNS
if getent hosts www.google.com > /dev/null 2>&1; then
    _add_test "Resolution DNS" true
else
    _add_test "Resolution DNS" false "Echec DNS"
fi

{% if profile.join_domain %}
# Jonction domaine AD
if realm list 2>/dev/null | grep -q "{{ profile.domain }}"; then
    _add_test "Jonction domaine AD" true "{{ profile.domain }}"
else
    _add_test "Jonction domaine AD" false "Domaine non trouve dans realm list"
fi
{% endif %}

{% if profile.machine_type == 'server' %}
# Service SSH
if systemctl is-active --quiet ssh 2>/dev/null || systemctl is-active --quiet sshd 2>/dev/null; then
    _add_test "Service SSH" true "En cours d'execution"
else
    _add_test "Service SSH" false "Service SSH inactif"
fi

# Auth par mot de passe desactivee
if grep -qE '^PasswordAuthentication\s+no' /etc/ssh/sshd_config 2>/dev/null; then
    _add_test "SSH - auth mot de passe" true "Desactivee"
else
    _add_test "SSH - auth mot de passe" false "Toujours active"
fi
{% else %}
# Service TeamViewer
if systemctl is-active --quiet teamviewerd 2>/dev/null; then
    _add_test "TeamViewer" true "En cours d'execution"
else
    _add_test "TeamViewer" false "Service inactif ou absent"
fi
{% endif %}

{% if ubuntu_packages %}
# Presence des paquets installes
{% for pkg in ubuntu_packages %}
if dpkg -s "{{ pkg }}" > /dev/null 2>&1; then
    _add_test "Paquet : {{ pkg }}" true
else
    _add_test "Paquet : {{ pkg }}" false "Non installe"
fi
{% endfor %}
{% endif %}

_smoke_json+="]"

# Envoi du rapport a OSIRIS
_smoke_body="{\"tests\":${_smoke_json}}"
if curl -s -X POST "$osiris_url/machines/$_osiris_mac/smoke-tests" \
    -H "Content-Type: application/json" \
    -d "$_smoke_body" --max-time 15; then
    echo "[$(ts)] Rapport smoke tests envoye."
else
    echo "[$(ts)] AVERTISSEMENT : Echec envoi rapport smoke tests."
fi

systemctl disable osiris-firstboot.service
