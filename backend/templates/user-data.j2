#cloud-config
autoinstall:
  version: 1
  locale: {{ profile.locale }}
  keyboard:
    layout: {{ profile.keyboard }}
  timezone: {{ profile.timezone }}
  storage:
    layout:
      name: direct
  identity:
    hostname: {{ machine.hostname }}
    username: {{ profile.default_user }}
    password: '{{ machine.password_hash }}'
  ssh:
    install-server: true
    allow-pw: true
{% if ssh_pubkey %}
    authorized-keys:
      - {{ ssh_pubkey }}
{% endif %}
{% if packages %}
  packages:
{% for pkg in packages %}
    - {{ pkg }}
{% endfor %}
{% endif %}
  early-commands:
    - curl -sf -X POST '{{ status_url }}?status=deploying' || true
  late-commands:
    - curl -sf -o /target/usr/local/bin/osiris-firstboot.sh '{{ osiris_url }}/firstboot-ubuntu/{{ mac }}'
    - chmod +x /target/usr/local/bin/osiris-firstboot.sh
    - printf '[Unit]\nDescription=OSIRIS First Boot\nAfter=network-online.target\nWants=network-online.target\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/osiris-firstboot.sh\nRemainAfterExit=yes\n[Install]\nWantedBy=multi-user.target\n' > /target/etc/systemd/system/osiris-firstboot.service
    - curtin in-target --target=/target -- systemctl enable osiris-firstboot.service
    - curl -sf -X POST '{{ status_url }}?status=deployed' || true
