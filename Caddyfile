# OSIRIS — Reverse proxy
#
# Port 443 : interface web en HTTPS
# Port 80  : routes iPXE (10.0.0.1) en HTTP pur, redirection HTTPS pour le reste

# Désactive les redirections HTTP→HTTPS automatiques de Caddy (on les gère manuellement)
{
    auto_https disable_redirects
}

# ── HTTPS — interface admin (10.0.0.1 et IP de gestion) ───────────────────────
https://10.0.0.1, https://192.168.1.18 {
    tls /etc/caddy/certs/osiris.crt /etc/caddy/certs/osiris.key

    handle /auth/* {
        reverse_proxy localhost:8000
    }
    handle /machines* {
        reverse_proxy localhost:8000
    }
    handle /organizations* {
        reverse_proxy localhost:8000
    }
    handle /users* {
        reverse_proxy localhost:8000
    }
    handle /profiles* {
        reverse_proxy localhost:8000
    }
    handle /images* {
        reverse_proxy localhost:8000
    }
    handle /audit-logs* {
        reverse_proxy localhost:8000
    }
    handle /ws/* {
        reverse_proxy localhost:8000
    }

    handle {
        root * /opt/osiris/frontend/dist
        try_files {path} /index.html
        file_server
    }
}

# ── HTTP 10.0.0.1 — routes iPXE (boot, cloud-init, fichiers statiques) ────────
# Pas de redirection HTTPS : les machines en cours de déploiement n'ont pas le cert
http://10.0.0.1 {
    handle /boot* {
        reverse_proxy localhost:8000
    }
    handle /cloud-init/* {
        reverse_proxy localhost:8000
    }
    handle /static/* {
        reverse_proxy localhost:8000
    }
    handle /machines/* {
        reverse_proxy localhost:8000
    }
}

# ── HTTP 192.168.1.18 — redirection vers HTTPS pour les navigateurs ────────────
http://192.168.1.18 {
    redir https://192.168.1.18{uri} 308
}
